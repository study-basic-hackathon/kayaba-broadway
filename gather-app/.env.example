# ============================================================
# gather-app 環境変数サンプル
# 各 apps/.dev.vars / .env にコピーして使う
# ============================================================

# LiveKit
LIVEKIT_API_KEY=devkey
LIVEKIT_API_SECRET=secret-at-least-32-chars-long!!

# ローカル:  ws://localhost:7880
# 本番:      wss://your-app.livekit.cloud  or  wss://your.oracle.host:7880
LIVEKIT_URL=ws://localhost:7880

# PartyKit
# ローカル:  ws://localhost:1999
# 本番:      wss://gather-party.<your-user>.partykit.dev
PARTYKIT_HOST=localhost:1999

# Cloudflare Workers
# ローカル:  http://localhost:8787
# 本番:      https://gather-api.<your-subdomain>.workers.dev
API_BASE_URL=http://localhost:8787
